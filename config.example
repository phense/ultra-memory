# ultra-memory — example consumer configuration (env vars).
#
# ultra-memory ships NO paths or content. Each consumer project sets these in its
# own environment (e.g. a sourced .config file, the cron wrapper, or the plugin's
# hook/MCP launch env). Copy, fill in your absolute paths, and source it. Keep the
# live DB and any filled-in copy OUT of the plugin repo — they are the consumer's
# private data (publish-public / data-private, spec §3.1).

# --- Storage (OPTIONAL override) ------------------------------------------------
# Canonical SQLite memory DB. The knowledge MCP and the hooks read this; the engine
# resolves it from config, NEVER from cwd (the MCP-launcher-ignores-cwd trap).
# DEFAULT (unset): the fixed global user-path ~/.ultra-memory/memory.db — the single
# store shared by every project. Set this ONLY to override that fixed location.
export ULTRA_MEMORY_DB="$HOME/.ultra-memory/memory.db"

# Legacy harness memory dir the one-time bootstrap import reads (the *.md files +
# MEMORY.md index). Used by memory_import; not needed once the DB is canonical.
export ULTRA_MEMORY_HARNESS_DIR="/abs/path/to/.claude/projects/<slug>/memory"

# Optional: the consumer's LLM-Wiki dir, if the wiki gateway is co-located.
export ULTRA_MEMORY_WIKI_DIR="/abs/path/to/consumer/wiki"

# --- Tier-2 wiki-maintenance (the wiki_maintenance beat / wiki_curate CLI) -------
# The active wiki root(s) maintenance curates (comma/pathsep-separated). Unset → the
# wiki_maintenance beat is a no-op (a pure-memory install). config.wiki_roots reads this.
# export ULTRA_MEMORY_WIKI_ROOTS="$HOME/.ultra-memory/wiki"
#
# The remaining wiki seams live in <project>/.ultra-memory/config.toml [maintenance]:
#   wiki_gateway        = "scripts/wiki_lib.py"   # the audited write gateway (create-page/log/…)
#   wiki_linter         = "module:function"       # OPTIONAL: a consumer linter supplying Stage-1
#                                                 # findings (resolved with <project>/scripts on
#                                                 # sys.path); absent → the engine's generic lint
#   wiki_merge_decider  = "module:function"       # OPTIONAL: (cosine, claim, cand_text) -> bool —
#                                                 # the grey-zone dedup merge decision (wire a
#                                                 # calibrated judge); absent → auto-merge only
#   wiki_graph_extractor = ["py", "extract.py", "{wiki_root}", "--out", "{graph_dir}"]  # OPTIONAL
#   [maintenance.wiki]  # OPTIONAL: override any WikiSchemaConfig field; absent → reference defaults
# A consumer whose wiki follows the reference Karpathy conventions needs none of the
# [maintenance.wiki] table — every default already matches.

# --- Maintenance failure notification (OPTIONAL) --------------------------------
# ultra-memory ships NO mail/notify transport. To be alerted when a maintenance run
# records beat errors, point this at YOUR notifier — a "module:function" resolved with
# <project>/scripts on sys.path (the same seam as wiki_linter). The function is called
# FAIL-OPEN with a NotifyEvent (.subject/.body/.errors/.ran/.run_ts/.project). Unset →
# a one-line stderr no-op (the plugin sends nothing).
#   In <project>/.ultra-memory/config.toml:  [maintenance]  notifier = "mymod:notify"
#   Or override here:                          export ULTRA_MEMORY_NOTIFIER="mymod:notify"
# Copy ultra_memory/maintenance/notify.py::example_notifier for SMTP / CLI shell-out /
# webhook / MCP-via-`claude -p` templates. Headless cron ⇒ no direct Gmail/M365 MCP;
# OAuth-only (no anthropic SDK / API key).
# export ULTRA_MEMORY_NOTIFIER="mymod:notify"

# --- knowledge MCP: caller privilege class --------------------------------------
# Fail-closed: anything other than an explicit trusted class is treated as the
# untrusted "subagent" (recall limited to project/reference; never user/feedback).
# Set to "orchestrator" only on the trusted top-level session's MCP instance.
export ULTRA_MEMORY_CALLER_CLASS="subagent"

# --- Session hooks --------------------------------------------------------------
# Cron/subagent role marker: when set, the session hooks no-op (non-interactive run).
# Leave UNSET for an interactive orchestrator session.
# export ULTRA_MEMORY_AGENT_ROLE="cron"

# Hook mode: 1 = shadow (log only, no injection), 0 = live (inject the rehydrate gist).
export ULTRA_MEMORY_SHADOW="0"

# SessionStart rehydration gist budget (chars). Bounds the no-LLM gist size.
export ULTRA_MEMORY_REHYDRATE_BUDGET="2000"

# --- Models (have sensible built-in defaults; override only to change them) ------
# Embedding model + dim for retrieval_core (default: BAAI/bge-small-en-v1.5, 384).
# export ULTRA_MEMORY_EMBED_MODEL="BAAI/bge-small-en-v1.5"
# Off-session LLM model for any claude-CLI chokepoint use (OAuth only, never the API).
# export ULTRA_MEMORY_MODEL="claude-sonnet-4-6"
